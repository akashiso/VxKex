IDD_DIALOG1 DIALOGEX 0, 0, 354, 302
	STYLE DS_3DLOOK | DS_CENTER | DS_MODALFRAME | DS_SHELLFONT | WS_CAPTION | WS_VISIBLE | WS_POPUP | WS_SYSMENU
	CAPTION "VxKex Global Settings"
	FONT 8, "Segoe UI", 400, 0, 1
BEGIN
	LTEXT			"Configure VxKex settings:", IDSTATIC, 7, 7, 133, 8, SS_LEFT

	GROUPBOX		"Logging", IDSTATIC, 7, 20, 340, 31
	AUTOCHECKBOX	"Ena&ble", IDC_ENABLELOGGING, 16, 34, 40, 9
	EDITTEXT		IDC_LOGDIR, 56, 32, 231, 12, ES_AUTOHSCROLL
	PUSHBUTTON		"B&rowse...", IDC_BROWSELOGDIR, 292, 31, 50, 14

	GROUPBOX		"System integration", IDSTATIC, 7, 56, 340, 55
	AUTOCHECKBOX	"Allow VxKex to be enabled for &MSI installers", IDC_ENABLEFORMSI, 16, 69, 250, 9
	AUTOCHECKBOX	"Bypass ""... is not a valid &Win32 application"" error message", IDC_CPIWBYPA, 16, 82, 250, 9
	AUTOCHECKBOX	"&Add VxKex to:", IDC_ADDTOMENU, 16, 95, 69, 9
	COMBOBOX		IDC_WHICHCONTEXTMENU, 90, 93, 110, 30, WS_TABSTOP | CBS_DROPDOWNLIST | CBS_HASSTRINGS

	LTEXT			"Configure applications that have VxKex enabled:", IDSTATIC, 7, 116, 200, 8, SS_LEFT
	CONTROL			"", IDC_LISTVIEW, WC_LISTVIEW, WS_TABSTOP | WS_BORDER | LVS_ALIGNLEFT | LVS_SHOWSELALWAYS | LVS_REPORT, 7, 129, 280, 144
	PUSHBUTTON		"A&dd...", IDC_NEWAPP, 292, 129, 50, 14
	PUSHBUTTON		"&Remove", IDC_REMOVEAPPS, 292, 148, 50, 14, WS_DISABLED
	PUSHBUTTON		"&Properties", IDC_PROPERTIES, 292, 167, 50, 14, WS_DISABLED

	PUSHBUTTON		"&OK", IDC_OK, 193, 281, 50, 14
	PUSHBUTTON		"&Cancel", IDC_CANCEL, 245, 281, 50, 14
	PUSHBUTTON		"Appl&y", IDC_APPLY, 297, 281, 50, 14
END