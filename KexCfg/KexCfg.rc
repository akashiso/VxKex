IDD_DIALOG1 DIALOGEX 0, 0, 354, 302
	STYLE DS_3DLOOK | DS_CENTER | DS_MODALFRAME | DS_SHELLFONT | WS_CAPTION | WS_VISIBLE | WS_POPUP | WS_SYSMENU
	CAPTION "VxKex 全域設定"
	FONT 8, "Microsoft Jhenghei", 400, 0, 1
BEGIN
	LTEXT			"配置 VxKex 設定：", IDSTATIC, 7, 7, 133, 8, SS_LEFT
	
	GROUPBOX		"日誌記錄", IDSTATIC, 7, 20, 340, 31
	AUTOCHECKBOX	"啟用(&B)", IDC_ENABLELOGGING, 16, 34, 40, 9
	EDITTEXT		IDC_LOGDIR, 56, 32, 231, 12, ES_AUTOHSCROLL
	PUSHBUTTON		"瀏覽(&R)...", IDC_BROWSELOGDIR, 292, 31, 50, 14

	GROUPBOX		"系統集成", IDSTATIC, 7, 56, 340, 55
	AUTOCHECKBOX	"允許 MSI 安裝程式啟用 VxKex(&M)", IDC_ENABLEFORMSI, 16, 69, 250, 9
	AUTOCHECKBOX	"繞過「……不是有效的 Win32 應用程式」錯誤消息(&W)", IDC_CPIWBYPA, 16, 82, 250, 9
	AUTOCHECKBOX	"將 VxKex 添加到：(&A)", IDC_ADDTOMENU, 16, 95, 95, 9
	COMBOBOX		IDC_WHICHCONTEXTMENU, 116, 93, 80, 30, WS_TABSTOP | CBS_DROPDOWNLIST | CBS_HASSTRINGS

	LTEXT			"配置已啟用 VxKex 的應用程式：", IDSTATIC, 7, 116, 200, 8, SS_LEFT
	CONTROL			"", IDC_LISTVIEW, WC_LISTVIEW, WS_TABSTOP | WS_BORDER | LVS_ALIGNLEFT | LVS_SHOWSELALWAYS | LVS_REPORT, 7, 129, 280, 144
	PUSHBUTTON		"添加(&D)...", IDC_NEWAPP, 292, 129, 50, 14
	PUSHBUTTON		"移除(&R)", IDC_REMOVEAPPS, 292, 148, 50, 14, WS_DISABLED
	PUSHBUTTON		"屬性(&P)", IDC_PROPERTIES, 292, 167, 50, 14, WS_DISABLED

	PUSHBUTTON		"確定(&O)", IDC_OK, 193, 281, 50, 14
	PUSHBUTTON		"取消(&C)", IDC_CANCEL, 245, 281, 50, 14
	PUSHBUTTON		"應用(&Y)", IDC_APPLY, 297, 281, 50, 14
END


LANGUAGE LANG_ENGLISH, SUBLANG_NEUTRAL

IDM_LISTVIEWITEMMENU MENU
BEGIN
	POPUP ""
	BEGIN
		MENUITEM "Open file locat&ion",	M_OPENFILELOCATION
		MENUITEM "&Run program",		M_RUNPROGRAM
		MENUITEM "Remo&ve from list",	M_REMOVE
